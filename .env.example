# WordPress GraphQL API Endpoint
# For local development, use: http://portfolio-backend.local/graphql
# For production, use: https://backend.shadrach-tuck.dev/graphql
#
# Match WPGraphQL + WPGraphQL for ACF (and ACF Pro) versions across local and production so the schema stays in sync.
#
# Vite bakes VITE_* into the bundle at BUILD time. Use .env.local for local-only overrides.
# The committed .env.production sets the remote GraphQL URL for `npm run build` so dist does not use .local.
# On Vercel, set VITE_WP_GRAPHQL_URL for Production and redeploy after changing it.
VITE_WP_GRAPHQL_URL=https://backend.shadrach-tuck.dev/graphql

# Environment (development, production)
VITE_ENV=production
